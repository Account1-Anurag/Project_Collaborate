{
  "name": "skill-exchange-monorepo",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "build": "npm -ws run build",
    "dev": "npm -ws run dev",
    "lint": "npm -ws run lint",
    "format": "npm -ws run format",
    "dev:web": "npm run dev -w web",
    "build:web": "npm run build -w web",
    "start:web": "npm run start -w web"
  },
  "engines": {
    "node": ">=18.18.0"
  }
}